DEBUG=1
SECRET_KEY=replace-me
ALLOWED_HOSTS=["localhost","127.0.0.1"]
DB_ENGINE=django.db.backends.postgresql
DB_NAME=replace-me
DB_USER=replace-me
DB_PASSWORD=replace-me
DB_HOST=localhost
DB_PORT=5432
DB_URI=
BROKER_URL=redis://localhost:6379/0
REDISS_ADDRESS=redis://localhost:6379/1
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-me
EMAIL_HOST_PASSWORD=replace-me
DEFAULT_FROM_EMAIL=no-reply@example.com
STRIPE_SECRET_KEY=replace-me
STRIPE_PUBLISHABLE_KEY=replace-me
STRIPE_WEBHOOK_SECRET=replace-me
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
CORS_ALLOWED_ORIGIN_REGEXES=["^https://.*\\.ngrok\\.app$"]
CSRF_TRUSTED_ORIGINS=["http://localhost:3000","https://*.ngrok.app"]
SENTRY_ENABLED=0
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
LOG_LEVEL=INFO
# Signup POST rate limit (anon, per IP). Lower in production if needed, e.g. 15/hour.
AUTH_SIGNUP_THROTTLE_RATE=30/hour
CELERY_SSL_CERT_REQS=REQUIRED
REDIS_SSL_CERT_REQS=REQUIRED
